{
  "backbone_arch": "tf_efficientnet_b6",
  "flow_arch": "conditional_flow_model",
  "feature_levels": 3,
  "coupling_layers": 8,
  "clamp_alpha": 1.9,
  "pos_embed_dim": 128,
  "lambda1": 1.0,
  "lambda2": 100.0,
  "label_smoothing": 0.02,
  "n_intra_centers": 5,
  "dataset": "mvtec",
  "img_size": 512,
  "msk_size": 128,
  "batch_size": 4,
  "lr": 0.0002,
  "lr_decay_epochs": [3, 6, 8],
  "lr_decay_rate": 0.1,
  "lr_warm": true,
  "lr_warm_epochs": 1,
  "lr_cosine": true,
  "temp": 0.5,
  "meta_epochs": 10,
  "sub_epochs": 4,
  "gpu": "0",
  "seed": 0,
  "print_freq": 50,
  "output_dir": "./outputs"
} 