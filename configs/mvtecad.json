{
  "backbone_arch": "tf_efficientnet_b6",
  "flow_arch": "conditional_flow_model",
  "feature_levels": 3,
  "coupling_layers": 12,
  "clamp_alpha": 1.9,
  "pos_embed_dim": 256,
  "lambda1": 1.0,
  "lambda2": 100.0,
  "label_smoothing": 0.02,
  "n_intra_centers": 10,
  "dataset": "mvtec",
  "img_size": 1024,
  "msk_size": 256,
  "batch_size": 8,
  "lr": 0.0002,
  "lr_decay_epochs": [48, 57, 88],
  "lr_decay_rate": 0.1,
  "lr_warm": true,
  "lr_warm_epochs": 2,
  "lr_cosine": true,
  "temp": 0.5,
  "meta_epochs": 100,
  "sub_epochs": 8,
  "gpu": "0",
  "seed": 0,
  "print_freq": 200,
  "output_dir": "./outputs"
} 